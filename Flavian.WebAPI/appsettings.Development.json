{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FlavianDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "DevSuperSecretKeyHere_ForDevelopmentOnly_MinLength32",
    "Issuer": "Flavian.API",
    "Audience": "Flavian.Client"
  },
  "AuthSecurity": {
    "AccessTokenMinutes": 120,
    "RefreshTokenDays": 30
  },
  "AppInfo": {
    "EnvironmentName": "Development",
    "ConfigSource": "appsettings.Development.json"
  }
}
