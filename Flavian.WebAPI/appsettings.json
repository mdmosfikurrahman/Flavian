{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "YourSuperSecretKeyHere_ChangeThisInProduction_MinLength32",
    "Issuer": "Flavian.API",
    "Audience": "Flavian.Client"
  },
  "AuthSecurity": {
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "SchemaSettings": {
    "DefaultSchema": "dbo"
  },
  "AppInfo": {
    "EnvironmentName": "Production",
    "ConfigSource": "appsettings.json"
  },
  "Service-Info": {}
}
